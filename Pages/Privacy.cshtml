@page
@model PrivacyModel
@{
    ViewData["Title"] = "Resume";
}

<div class="container resume-page">
    <div class="resume-surface">
        <div class="resume-header">
            <div>
                <div class="resume-name">Joeb Englatera</div>
                <div class="small-muted fw-semibold">BSIT Fresh Graduate | Aspiring Web Developer</div>
                <div class="small-muted">
                    Email:
                    <a href="mailto:joebenglatera@example.com" class="text-decoration-none">joebenglatera@example.com</a>
                    &nbsp;|&nbsp; Location: Philippines
                </div>
            </div>

            <div class="no-print d-flex gap-2 flex-wrap justify-content-end">
                <button type="button" class="btn btn-outline-light" onclick="window.print()">
                    Print / Save as PDF
                </button>
                <a class="btn btn-primary" asp-area="" asp-page="/Index">
                    Back to Portfolio
                </a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <h2 class="section-title">Professional Summary</h2>
                <p class="muted mb-3">
                    Detail-oriented BSIT fresh graduate focused on building clean, responsive web applications.
                    Knowledgeable in C#, ASP.NET Core, Razor Pages, and SQL, with strong problem-solving and
                    collaboration skills.
                </p>

                <h2 class="section-title mt-4">Education</h2>
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-title">BS in Information Technology (BSIT)</div>
                        <div class="small-muted">Your School Name • Graduation: 2026 (adjust)</div>
                        <div class="muted mt-1">
                            Relevant coursework: Web Development, Database Systems, Software Engineering.
                        </div>
                    </div>
                </div>

                <h2 class="section-title mt-4">Projects</h2>
                <div class="card-glass card-2">
                    <div class="fw-semibold mb-2">Selected Web App Work</div>

                    <div class="mb-3">
                        <div class="fw-semibold">Student Management System</div>
                        <div class="small-muted">ASP.NET Core • CRUD • SQL integration</div>
                    </div>

                    <div class="mb-3">
                        <div class="fw-semibold">Admission/Enrollment Web App</div>
                        <div class="small-muted">Razor Pages • Validation • Responsive UI</div>
                    </div>

                    <div>
                        <div class="fw-semibold">Portfolio UI (This Project)</div>
                        <div class="small-muted">Static sections • Print-friendly resume</div>
                    </div>
                </div>

                <h2 class="section-title mt-4">Experience</h2>
                <div class="card-glass card-2">
                    <div class="fw-semibold mb-2">Fresh Graduate</div>
                    <div class="muted">
                        Built multiple school projects and practice apps using ASP.NET Core and SQL.
                        Ready to learn quickly and contribute to a real team workflow.
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <h2 class="section-title">Core Skills</h2>
                <div class="skill-tags">
                    <span class="chip">C#</span>
                    <span class="chip">ASP.NET Core</span>
                    <span class="chip">Razor Pages</span>
                    <span class="chip">SQL</span>
                    <span class="chip">HTML</span>
                    <span class="chip">CSS</span>
                    <span class="chip">JavaScript</span>
                    <span class="chip">Bootstrap</span>
                    <span class="chip">Debugging</span>
                    <span class="chip">Git/GitHub</span>
                </div>

                <h2 class="section-title mt-4">Key Strengths</h2>
                <div class="card-glass card-2">
                    <ul class="mb-0 muted" style="padding-left: 1.1rem;">
                        <li class="mb-2">Clean UI structure and responsive layout mindset.</li>
                        <li class="mb-2">Strong understanding of fundamentals and self-learning habits.</li>
                        <li class="mb-2">Good communication and teamwork in group projects.</li>
                    </ul>
                </div>

                <h2 class="section-title mt-4">Availability</h2>
                <div class="card-glass card-2">
                    <div class="muted">
                        Open to internships / entry-level roles.
                        Can start: <span class="fw-semibold">Immediately (adjust)</span>.
                    </div>
                </div>

                <h2 class="section-title mt-4">References</h2>
                <div class="card-glass card-2">
                    <div class="muted">Available upon request.</div>
                </div>
            </div>
        </div>
    </div>
</div>
